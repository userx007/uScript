LOAD_PLUGIN CP2112

CP2112.I2C write A550FF
CP2112.I2C read 2
CP2112.I2C wrrd 0000:2
CP2112.I2C wrrdf i2c_seq.bin
CP2112.I2C scan

CP2112.I2C cfg  addr=0x42 clock=100000

CP2112.I2C open addr=0x42 clock=100000 device=4
CP2112.I2C script cp2112_i2c.txt
CP2112.I2C close

CP2112.I2C write A550FF
CP2112.I2C read 2
CP2112.I2C wrrd 0000:2
CP2112.I2C wrrdf i2c_seq.bin
CP2112.I2C scan

# sudo chmod 666 /dev/hidraw4